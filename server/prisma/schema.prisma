generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Telemetry {
  id             Int      @id @default(autoincrement())
  deviceId       String
  timestamp      DateTime
  lat            Float
  lon            Float
  gpsValid       Boolean  @default(false)
  gpsSatellites  Int      @default(0)
  weight         Float
  weightValid    Boolean  @default(false)
  gpsQuality     Int      @default(0)
  wifiClients    String? 
  cpuTempC       Float?
  lteRssiDbm     Int?
  lteAccessTech  String?
  eventsReaderOk Boolean  @default(false)
}

// prisma/schema.prisma
model StorageZone {
  id         Int      @id @default(autoincrement())
  name       String
  lat        Float
  lon        Float
  radius     Float    @default(15.0)
  ingredient String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model DeviceEvent {
  id         Int      @id @default(autoincrement())
  deviceId   String
  type       String   // Сюда будет падать 'sms' или 'call'
  timestamp  DateTime // Время с устройства
  fromNumber String   // Номер телефона, например '+79991234567'
  text       String?  // Текст (опционально, так как у звонков текста нет)
  createdAt  DateTime @default(now()) // Время, когда сервер получил пакет
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // Здесь будет лежать зашифрованный пароль
  role      String   @default("USER") // Роли: 'ADMIN' или 'USER'
  createdAt DateTime @default(now())
}

// Модель самого рациона (например, "Рацион для дойных коров")
model Ration {
  id          Int                @id @default(autoincrement())
  name        String             // Название рациона
  createdAt   DateTime           @default(now())
  
  // Связь: у одного рациона может быть много ингредиентов
  ingredients RationIngredient[] 
}

// Модель ингредиента внутри рациона
model RationIngredient {
  id              Int      @id @default(autoincrement())
  
  // Связь с рационом
  rationId        Int
  ration          Ration   @relation(fields: [rationId], references: [id], onDelete: Cascade)
  
  // Поля из твоей задачи:
  name            String   // Имя ингредиента
  plannedWeight   Float    // Вес план (в кг)
  dryMatterWeight Float    // Вес СВ (Сухое вещество)
}