// prisma/schema.prisma
generator client {
  provider = "prisma-client"  // ← важно: без "-js" для Prisma 7
  output   = "../src/generated"
}

datasource db {
  provider = "sqlite"
  // url не указываем здесь — он в prisma.config.js
}

model Telemetry {
  id        Int      @id @default(autoincrement())
  timestamp DateTime
  deviceId  String
  weight    Float
  lat       Float
  lon       Float
  createdAt DateTime @default(now())
}