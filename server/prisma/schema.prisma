generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Telemetry {
  id        Int      @id @default(autoincrement())
  timestamp DateTime
  weight    Float
  lat       Float
  lon       Float
  deviceId  String
}

