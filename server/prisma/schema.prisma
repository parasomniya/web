// prisma/schema.prisma
generator client {
  provider = "prisma-client"  // ← важно: без "-js" для Prisma 7
  output   = "../src/generated"
}

datasource db {
  provider = "sqlite"
  // url не указываем здесь — он в prisma.config.js
}

model Telemetry {
  id        Int      @id @default(autoincrement())
  timestamp DateTime
  deviceId  String
  weight    Float
  lat       Float
  lon       Float
  createdAt DateTime @default(now())
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  role         String   // "admin", "director", "guest"
  createdAt    DateTime @default(now())
}

// prisma/schema.prisma
model StorageZone {
  id         Int      @id @default(autoincrement())
  name       String
  lat        Float
  lon        Float
  radius     Float    @default(15.0)
  ingredient String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}