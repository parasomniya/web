generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Telemetry {
  id             Int      @id @default(autoincrement())
  deviceId       String
  timestamp      DateTime
  lat            Float
  lon            Float
  gpsValid       Boolean  @default(false)
  gpsSatellites  Int      @default(0)
  weight         Float
  weightValid    Boolean  @default(false)
  gpsQuality     Int      @default(0)
  wifiClients    String? 
  cpuTempC       Float?
  lteRssiDbm     Int?
  lteAccessTech  String?
  eventsReaderOk Boolean  @default(false)
}

model RtkTelemetry {
  id            Int      @id @default(autoincrement())
  deviceId      String
  timestamp     DateTime
  lat           Float
  lon           Float
  rtkQuality    String?
  rtkAge        Float?
  speed         Float?
  course        Float?
  supplyVoltage Float?
  satellites    Int?
  fixType       String?
  rawPayload    String
  createdAt     DateTime @default(now())
}

model StorageZone {
  id         Int      @id @default(autoincrement())
  name       String
  lat        Float
  lon        Float
  radius     Float    @default(15.0)
  shapeType  String   @default("CIRCLE")
  sideMeters Float?
  polygonCoords String?
  squareMinLat Float?
  squareMinLon Float?
  squareMaxLat Float?
  squareMaxLon Float?
  ingredient String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model DeviceEvent {
  id         Int      @id @default(autoincrement())
  deviceId   String
  type       String   
  timestamp  DateTime 
  fromNumber String   
  text       String?  
  createdAt  DateTime @default(now()) 
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String?   @unique
  password  String   
  role      UserRole @default(GUEST) 
  createdAt DateTime @default(now())
}

model Ration {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  createdAt   DateTime @default(now())
  isActive        Boolean            @default(false)
  ingredients     RationIngredient[] 
  
  // Связи для замесов и групп
  livestockGroups LivestockGroup[]
  batches         Batch[]
}

model RationIngredient {
  id              Int      @id @default(autoincrement())
  rationId        Int
  ration          Ration   @relation(fields: [rationId], references: [id], onDelete: Cascade)
  
  name            String   
  plannedWeight   Float    
  dryMatterWeight Float    
}

enum UserRole {
  ADMIN
  DIRECTOR
  GUEST
}

// =========================================================
// НОВЫЕ МОДЕЛИ ДЛЯ ФАКТИЧЕСКИХ ЗАМЕСОВ И ПОГОЛОВЬЯ
// =========================================================

model LivestockGroup {
  id          Int      @id @default(autoincrement())
  name        String   
  headcount   Int      
  
  rationId    Int?
  ration      Ration?  @relation(fields: [rationId], references: [id])

  lat         Float?
  lon         Float?
  radius      Float    @default(30.0)

  batches     Batch[]  
}

model Batch {
  id              Int      @id @default(autoincrement())
  deviceId        String   
  
  startTime       DateTime @default(now())
  endTime         DateTime? 
  
  // Пока делаем опциональными для MVP-теста (так как мы еще не привязываем их жестко к Excel-рациону)
  rationId        Int?     
  ration          Ration?  @relation(fields: [rationId], references: [id])
  groupId         Int?     
  group           LivestockGroup? @relation(fields: [groupId], references: [id])

  startWeight     Float    @default(0) 
  endWeight       Float?   
  
  hasViolations   Boolean  @default(false)

  actualIngredients BatchIngredient[]
}

model BatchIngredient {
  id              Int      @id @default(autoincrement())
  
  batchId         Int
  batch           Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  ingredientName  String   
  
  plannedWeight   Float?   // Пока опционально
  actualWeight    Float    
  
  isViolation     Boolean  @default(false)

  addedAt         DateTime @default(now())
}
