generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Telemetry {
  id             Int      @id @default(autoincrement())
  deviceId       String
  timestamp      DateTime
  lat            Float
  lon            Float
  gpsValid       Boolean  @default(false)
  gpsSatellites  Int      @default(0)
  weight         Float
  weightValid    Boolean  @default(false)
  gpsQuality     Int      @default(0)
  wifiClients    String? 
  cpuTempC       Float?
  lteRssiDbm     Int?
  lteAccessTech  String?
  eventsReaderOk Boolean  @default(false)

  @@index([deviceId, timestamp])
  @@index([timestamp])
}

model RtkTelemetry {
  id            Int      @id @default(autoincrement())
  deviceId      String
  timestamp     DateTime
  lat           Float
  lon           Float
  rtkQuality    String?
  rtkAge        Float?
  speed         Float?
  course        Float?
  supplyVoltage Float?
  satellites    Int?
  fixType       String?
  rawPayload    String
  createdAt     DateTime @default(now())

  @@index([deviceId, timestamp])
  @@index([timestamp])
}

model StorageZone {
  id         Int      @id @default(autoincrement())
  name       String
  lat        Float
  lon        Float
  radius     Float    @default(15.0)
  shapeType  String   @default("CIRCLE")
  sideMeters Float?
  polygonCoords String?
  squareMinLat Float?
  squareMinLon Float?
  squareMaxLat Float?
  squareMaxLon Float?
  ingredient String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  livestockGroups LivestockGroup[]
}

model DeviceEvent {
  id         Int      @id @default(autoincrement())
  deviceId   String
  type       String   
  timestamp  DateTime 
  fromNumber String   
  text       String?  
  createdAt  DateTime @default(now()) 
}

model DigestSettings {
  id             Int      @id
  enabled        Boolean  @default(false)
  senderEmail    String   @default("")
  sendTime       String   @default("08:00")
  timezone       String   @default("Asia/Novosibirsk")
  recipientsJson String   @default("[]")
  lastSentAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TelemetrySettings {
  id                     Int      @id
  batchStartThresholdKg  Int      @default(30)
  leftoverThresholdKg    Int      @default(50)
  unloadDropThresholdKg  Int      @default(200)
  unloadMinPeakKg        Int      @default(400)
  unloadUpdateDeltaKg    Int      @default(1)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String?   @unique
  password  String   
  role      UserRole @default(GUEST) 
  createdAt DateTime @default(now())
}

model Ration {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  createdAt   DateTime @default(now())
  isActive        Boolean            @default(false)
  ingredients     RationIngredient[] 
  
  // Связи для замесов и групп
  livestockGroups LivestockGroup[]
  batches         Batch[]
}

model RationIngredient {
  id              Int      @id @default(autoincrement())
  rationId        Int
  ration          Ration   @relation(fields: [rationId], references: [id], onDelete: Cascade)
  
  name            String   
  plannedWeight   Float    
  dryMatterWeight Float    
}

enum UserRole {
  ADMIN
  DIRECTOR
  GUEST
}

// =========================================================
// НОВЫЕ МОДЕЛИ ДЛЯ ФАКТИЧЕСКИХ ЗАМЕСОВ И ПОГОЛОВЬЯ
// =========================================================

model LivestockGroup {
  id          Int      @id @default(autoincrement())
  name        String   
  headcount   Int      
  
  rationId    Int?
  ration      Ration?  @relation(fields: [rationId], references: [id])

  storageZoneId Int?
  storageZone   StorageZone? @relation(fields: [storageZoneId], references: [id])

  lat         Float?
  lon         Float?
  radius      Float    @default(30.0)

  batches     Batch[]  
}

model Batch {
  id              Int      @id @default(autoincrement())
  deviceId        String   
  
  startTime       DateTime @default(now())
  endTime         DateTime? 
  
  // Пока делаем опциональными для MVP-теста (так как мы еще не привязываем их жестко к Excel-рациону)
  rationId        Int?     
  ration          Ration?  @relation(fields: [rationId], references: [id])
  groupId         Int?     
  group           LivestockGroup? @relation(fields: [groupId], references: [id])

  startWeight     Float    @default(0) 
  endWeight       Float?   
  
  hasViolations   Boolean  @default(false)

  actualIngredients BatchIngredient[]
  violations        Violation[]
}

model BatchIngredient {
  id              Int      @id @default(autoincrement())
  
  batchId         Int
  batch           Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  ingredientName  String   
  
  plannedWeight   Float?   // Пока опционально
  actualWeight    Float    
  
  isViolation     Boolean  @default(false)

  addedAt         DateTime @default(now())
}

model Violation {
  id               Int               @id @default(autoincrement())
  batchId          Int?
  batch            Batch?            @relation(fields: [batchId], references: [id], onDelete: SetNull)
  deviceId         String
  code             String
  title            String
  componentKey     String            @default("")
  componentName    String?
  message          String
  category         ViolationCategory @default(BUSINESS)
  status           ViolationStatus   @default(OPEN)
  source           String            @default("system")
  planWeight       Float?
  actualWeight     Float?
  deviation        Float?
  deviationPercent Float?
  detectedAt       DateTime          @default(now())
  resolvedAt       DateTime?
  comment          String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([batchId, code, componentKey])
  @@index([deviceId, detectedAt])
  @@index([status, detectedAt])
}

model TechnicalWarning {
  id         Int                    @id @default(autoincrement())
  scopeKey   String
  deviceId   String?
  code       String
  title      String
  message    String
  severity   String
  status     TechnicalWarningStatus @default(OPEN)
  detailsJson String?
  firstSeenAt DateTime              @default(now())
  lastSeenAt  DateTime              @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([scopeKey, code])
  @@index([status, lastSeenAt])
}

enum ViolationStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  RESOLVED
}

enum ViolationCategory {
  BUSINESS
  LEFTOVER
  TECHNICAL
}

enum TechnicalWarningStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}
