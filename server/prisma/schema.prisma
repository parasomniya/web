generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Telemetry {
  id             Int      @id @default(autoincrement())
  deviceId       String
  timestamp      DateTime
  lat            Float
  lon            Float
  gpsValid       Boolean  @default(false)
  gpsSatellites  Int      @default(0)
  weight         Float
  weightValid    Boolean  @default(false)
  gpsQuality     Int      @default(0)
  wifiClients    String? 
  cpuTempC       Float?
  lteRssiDbm     Int?
  lteAccessTech  String?
  eventsReaderOk Boolean  @default(false)
}

// prisma/schema.prisma
model StorageZone {
  id         Int      @id @default(autoincrement())
  name       String
  lat        Float
  lon        Float
  radius     Float    @default(15.0)
  ingredient String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}