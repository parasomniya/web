generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Telemetry {
  id        Int      @id @default(autoincrement())
  timestamp DateTime
  weight    Float
  lat       Float
  lon       Float
  deviceId  String
}

model StorageZone {
  id        Int      @id @default(autoincrement())
  name      String
  points    String   // Храним координаты как строку
  active    Boolean  @default(true) // ДОБАВИЛИ ЭТО ПОЛЕ
}
