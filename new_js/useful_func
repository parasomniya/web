/**
 * Вычисляет расстояние между двумя точками по формуле гаверсинуса.
 * @param {number} lat1 - Широта первой точки (градусы)
 * @param {number} lon1 - Долгота первой точки (градусы)
 * @param {number} lat2 - Широта второй точки (градусы)
 * @param {number} lon2 - Долгота второй точки (градусы)
 * @returns {number} Расстояние в метрах
 */
function getDistance(lat1, lon1, lat2, lon2) {
  const R = 6371000; // Средний радиус Земли в метрах
  const toRad = deg => deg * Math.PI / 180;

  const phi1 = toRad(lat1);
  const phi2 = toRad(lat2);
  const dPhi = toRad(lat2 - lat1);
  const dLambda = toRad(lon2 - lon1);

  const sinDPhi2 = Math.sin(dPhi / 2);
  const sinDLambda2 = Math.sin(dLambda / 2);

  let a = sinDPhi2 * sinDPhi2 + 
          Math.cos(phi1) * Math.cos(phi2) * 
          sinDLambda2 * sinDLambda2;

  // Защита от микропереполнения float: a может стать 1.0000000000000002
  if (a > 1) a = 1;

  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  return R * c;
}

/**
 * Проверяет, находится ли погрузчик в какой либо из зон.
 * @param {number} lat - Широта погрузчика (градусы)
 * @param {number} lon1 - Долгота погрузчика (градусы)
 * @param {array} zonelist - Массив с данными всех зон
 * @returns {string} Название зоны, в которой находится погрузчик
 * @returns {null} Если погрузчик ни в одной из зон 
 */
function findZone(lat, lon, zoneList)
{
    let distance
    for (const zone of zoneList)
    {
        distance = getDistance(lat,lon,zone.lat,zone.lon)
        if (distance <= zone.radius)
        {
            return zone.name
        }
    }
    return null
}


/**
 * Обрабатывает массив строк из Excel с рационами
 * @param {Array} rawRows - Массив объектов с русскими ключами
 * @returns {Object} Результат: { success, data, errors }
 */
function processRationRows(rawRows) {
  const result = {
    success: true,
    data: [],
    errors: []
  };

  rawRows.forEach((row, index) => {
    const lineNumber = index + 1; // Номер строки для сообщений об ошибках

    // === 1. Очистка: пропускаем полностью пустые строки ===
    const values = Object.values(row);
    const isEmptyRow = values.every(val => 
      val === undefined || val === null || String(val).trim() === ''
    );
    if (isEmptyRow) {
      return; // Пропускаем пустую строку
    }

    // === 2. Маппинг колонок и очистка данных ===
    const name = row['Ингредиент'] ? String(row['Ингредиент']).trim() : '';
    const plannedWeightRaw = row['План'];
    const dryMatterWeightRaw = row['СВ'];

    // === 3. Валидация: План (plannedWeight) ===
    const plannedWeight = Number(plannedWeightRaw);
    if (isNaN(plannedWeight) || plannedWeight <= 0) {
      result.errors.push(`Строка ${lineNumber}: Вес '${plannedWeightRaw}' не является числом или меньше/равен 0`);
      result.success = false;
      return; // Прерываем обработку этой строки, переходим к следующей
    }

    // === 4. Валидация: СВ (dryMatterWeight) ===
    const dryMatterWeight = Number(dryMatterWeightRaw);
    if (isNaN(dryMatterWeight) || dryMatterWeight < 0) {
      result.errors.push(`Строка ${lineNumber}: Сухое вещество '${dryMatterWeightRaw}' не является числом или меньше 0`);
      result.success = false;
      return;
    }

    // === 5. Логика физики: СВ не может быть больше общего веса ===
    if (dryMatterWeight > plannedWeight) {
      result.errors.push(`Строка ${lineNumber}: Сухое вещество (${dryMatterWeight}) не может быть больше планового веса (${plannedWeight})`);
      result.success = false;
      return;
    }

    // === 6. Все проверки пройдены — добавляем валидную строку в результат ===
    result.data.push({
      name,
      plannedWeight,
      dryMatterWeight
    });
  });

  return result;
}


/**
 * Детектор нарушений - сравнивает план и факт
 * @param {Array} planArr - Массив ингредиентов с плановым весом
 * @param {Array} factArr - Массив фактически загруженных компонентов
 * @param {number} threshold - Допустимая погрешность в % (по умолчанию 10)
 * @returns {Object} { matches: [], violations: [] }
 */
function checkViolations(planArr, factArr, threshold = 10) {
  const result = {
    matches: [],
    violations: []
  };

  // 1. Проверяем на наличие 'Unknown' компонентов
  const unknownComponents = factArr.filter(item => 
    item.name === 'Unknown' || item.name === undefined || item.name === null
  );
  
  if (unknownComponents.length > 0) {
    unknownComponents.forEach(item => {
      result.violations.push({
        type: 'unknown_component',
        message: 'Загружен нераспознанный компонент',
        component: item.name || 'Unknown',
        actualWeight: item.actualWeight
      });
    });
  }

  // 2. Создаем карту плановых ингредиентов для быстрого поиска
  const planMap = new Map();
  planArr.forEach(item => {
    planMap.set(item.name, item);
  });

  // 3. Сопоставляем факт с планом
  factArr.forEach(factItem => {
    // Пропускаем Unknown компоненты - они уже обработаны выше
    if (factItem.name === 'Unknown' || !factItem.name) {
      return;
    }

    const planItem = planMap.get(factItem.name);

    if (planItem) {
      // Компонент найден в плане
      const plannedWeight = planItem.plannedWeight;
      const actualWeight = factItem.actualWeight;
      
      // Рассчитываем процентное отклонение
      // Формула: ((факт - план) / план) * 100
      const deviationPercent = ((actualWeight - plannedWeight) / plannedWeight) * 100;
      const absDeviation = Math.abs(deviationPercent);

      // Создаем объект сравнения
      const comparison = {
        component: factItem.name,
        plannedWeight,
        actualWeight,
        deviationPercent: Math.round(deviationPercent * 100) / 100, // округляем до 2 знаков
        dryMatterPlan: planItem.dryMatterWeight,
        dryMatterFact: factItem.dryMatterWeight
      };

      // Проверяем, превышает ли отклонение порог
      if (absDeviation > threshold) {
        // Определяем тип нарушения
        const violationType = deviationPercent > 0 ? 'overweight' : 'underweight';
        const message = deviationPercent > 0 
          ? `Перевес по ${factItem.name} на ${Math.round(absDeviation)}%`
          : `Недовес по ${factItem.name} на ${Math.round(absDeviation)}%`;

        result.violations.push({
          type: violationType,
          message,
          component: factItem.name,
          plannedWeight,
          actualWeight,
          deviationPercent: comparison.deviationPercent
        });
      } else {
        // Отклонение в пределах нормы
        result.matches.push(comparison);
      }
    } else {
      // Компонент есть в факте, но нет в плане
      result.violations.push({
        type: 'unexpected_component',
        message: `Загружен компонент вне плана: ${factItem.name}`,
        component: factItem.name,
        actualWeight: factItem.actualWeight
      });
    }
  });

  // 4. Проверяем, все ли плановые компоненты были загружены
  planArr.forEach(planItem => {
    const factItem = factArr.find(f => f.name === planItem.name);
    if (!factItem) {
      // Компонент есть в плане, но нет в факте
      result.violations.push({
        type: 'missing_component',
        message: `Не загружен плановый компонент: ${planItem.name}`,
        component: planItem.name,
        plannedWeight: planItem.plannedWeight,
        actualWeight: 0,
        deviationPercent: -100
      });
    }
  });

  return result;
}
